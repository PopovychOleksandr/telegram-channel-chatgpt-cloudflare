{
  "name": "telegram-channel-chatgpt-cloudflare",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Private Telegram MCP server for ChatGPT on Cloudflare Workers and D1",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "test": "node --test",
    "check": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "db:local": "wrangler d1 migrations apply telegram-channel-chatgpt --local",
    "db:remote": "wrangler d1 migrations apply telegram-channel-chatgpt --remote"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "wrangler": "^4.113.0"
  }
}
